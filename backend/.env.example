# ====================
# SERVER CONFIGURATION
# ====================

# Port the server will run on (default: 5001)
PORT=5001

# Environment: development, production, or test
NODE_ENV=development


# ====================
# DATABASE CONFIGURATION
# ====================

# MySQL database host (use localhost for XAMPP)
DB_HOST=localhost

# MySQL username (default for XAMPP is 'root')
DB_USER=root

# MySQL password (leave empty for XAMPP default)
DB_PASSWORD=

# MySQL database name (create this database first)
DB_NAME=mwambo_store


# ====================
# JWT AUTHENTICATION
# ====================

# Secret key for JWT tokens - use a long, random string (min 32 chars)
# Generate one with: openssl rand -hex 32
JWT_SECRET=your_very_long_random_secret_here_min_32_chars_change_this

# How long JWT tokens are valid (e.g., 7d, 30d, 1h)
JWT_EXPIRE=7d


# ====================
# FRONTEND URL
# ====================

# URL of your frontend application (for CORS and email links)
FRONTEND_URL=http://localhost:8080


# ====================
# EMAIL CONFIGURATION (Nodemailer)
# ====================

# For Gmail: use smtp.gmail.com
EMAIL_HOST=smtp.gmail.com

# Port: 587 for TLS, 465 for SSL
EMAIL_PORT=587

# Your Gmail address
EMAIL_USER=your_email@gmail.com

# For Gmail: Use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_16_char_app_password

# From address for emails (usually same as EMAIL_USER)
EMAIL_FROM="Mwambo Store" <your_email@gmail.com>